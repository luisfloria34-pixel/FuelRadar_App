{
  "expo": {
    "name": "FuelRadar",
    "slug": "fuelradar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fuelradar",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.luishustler.fuelradar",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "FuelRadar benötigt deinen Standort, um Tankstellen in deiner Nähe zu finden und die günstigsten Preise anzuzeigen.",
        "NSLocationAlwaysUsageDescription": "FuelRadar benötigt deinen Standort im Hintergrund, um dich zu benachrichtigen, wenn Preise in deiner Nähe fallen.",
        "NSUserNotificationsUsageDescription": "FuelRadar benachrichtigt dich, wenn Kraftstoffpreise unter deinen Zielpreis fallen.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "aps-environment": "production"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A0A0B"
      },
      "edgeToEdgeEnabled": true,
      "usesCleartextTraffic": true,
      "package": "com.luishustler.fuelradar",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.USE_EXACT_ALARM"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "REPLACE_WITH_GOOGLE_MAPS_API_KEY"
        }
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0A0A0B"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "FuelRadar benötigt deinen Standort, um Tankstellen in der Nähe zu finden und die günstigsten Kraftstoffpreise anzuzeigen."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#32D74B",
          "defaultChannel": "default"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "839dbd6f-2514-458e-b99c-3e2138c3625e"
      }
    },
    "owner": "swyone1"
  }
}
