{
  "expo": {
    "name": "FuelRadar",
    "slug": "fuelradar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fuelradar",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fuelradar.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Find fuel stations near your location",
        "NSLocationAlwaysUsageDescription": "Get alerts when nearby prices drop",
        "NSUserNotificationsUsageDescription": "FuelRadar sends you a notification when fuel prices drop below your set threshold."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A0A0B"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.fuelradar.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0A0A0B"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "FuelRadar needs your location to find nearby gas stations and best fuel prices."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#32D74B"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
