# FuelRadar – Frontend environment variables
# Copy this file to .env and fill in your NEW Supabase project values.
# Never commit .env to git.

# ── Supabase (new clean FuelRadar-only project) ─────────────────────────────
# Get these from: app.supabase.com → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# ── FastAPI backend ──────────────────────────────────────────────────────────
# Your deployed backend URL (Render, Railway, Fly.io, etc.)
# Leave empty to skip backend sync (favorites/alerts won't persist to server).
EXPO_PUBLIC_API_URL=https://YOUR_BACKEND_URL_HERE
