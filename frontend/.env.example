# FuelRadar – Frontend environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── Supabase ─────────────────────────────────────────────────────────────────
# Get from: app.supabase.com → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# ── Google Maps (Android map rendering) ──────────────────────────────────────
# Get from: console.cloud.google.com → APIs & Services → Credentials
# Also update android.config.googleMaps.apiKey in app.json with the same value.
# Without this, the map on Android shows an authorization error watermark.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# ── Optional: Legacy FastAPI backend ─────────────────────────────────────────
# Leave empty — all backend logic now runs via Supabase Edge Functions.
# EXPO_PUBLIC_API_URL=https://YOUR_BACKEND_URL_HERE
