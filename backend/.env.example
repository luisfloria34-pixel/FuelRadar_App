# FuelRadar Backend - Environment Variables Template
# Copy this to .env and fill in the values

# ======================
# REQUIRED
# ======================

# Tankerkönig API Key (get from https://creativecommons.tankerkoenig.de/)
TANKERKOENIG_API_KEY=

# Database URL (PostgreSQL)
# Local: postgresql://localhost/fuelradar
# Render: Automatically set from render.yaml
DATABASE_URL=postgresql://localhost/fuelradar

# ======================
# OPTIONAL
# ======================

# Redis URL for caching
# Local: redis://localhost:6379
# Render: Automatically set from render.yaml
REDIS_URL=redis://localhost:6379

# Alert check interval in minutes (default: 5)
ALERT_CHECK_MINUTES=5

# Cache TTL in seconds (default: 60)
CACHE_TTL_SECONDS=60

# Debug mode (default: false)
DEBUG=false

# ======================
# LEGACY (for MongoDB support)
# ======================
MONGO_URL="mongodb://localhost:27017"
DB_NAME="fuelradar"
