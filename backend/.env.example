# FuelRadar – Backend environment variables
# Copy this file to .env and fill in real values.
# Never commit .env to git.

# ── TankerKönig API ──────────────────────────────────────────────────────────
# Register at: https://creativecommons.tankerkoenig.de
# Also set this in Supabase Secrets for Edge Functions:
#   npx supabase secrets set TANKERKOENIG_API_KEY=YOUR_KEY --project-ref jorjciajyaqzjuflxefv
TANKERKOENIG_API_KEY=your-tankerkoenig-api-key

# ── Database (Supabase PostgreSQL) ───────────────────────────────────────────
# Get from: app.supabase.com → Settings → Database → Connection string → URI
# Use the "URI" format (not the "JDBC" one). Replace [YOUR-PASSWORD] with
# the database password you set when creating the Supabase project.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.jorjciajyaqzjuflxefv.supabase.co:5432/postgres

# ── Supabase (for edge function calls from the backend, if needed) ───────────
# Get from: app.supabase.com → Settings → API
SUPABASE_URL=https://jorjciajyaqzjuflxefv.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ── Redis (optional – used for price caching) ────────────────────────────────
# Provide a Redis URL or leave as localhost for local dev.
# On Render: add a free Redis service and copy the internal URL.
REDIS_URL=redis://localhost:6379

# ── App behaviour ────────────────────────────────────────────────────────────
DEBUG=false
ALERT_CHECK_MINUTES=5
CACHE_TTL_SECONDS=60
